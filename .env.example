# =============================================================
# ts-appc-gateway — required configuration
# Copy to .env and fill in values before running.
# =============================================================

# The ingress address(es). Comma-separated host CIDRs.
# /32 for IPv4 hosts, /128 for IPv6 hosts. CIDR notation is required —
# the value is passed directly to tailscale --advertise-routes, which
# only accepts CIDR format (bare IPs are rejected).
#
# All ingress addresses resolve to the same SNI allowlist and proxy behavior.
# dnsmasq returns an A record for IPv4 and AAAA for IPv6 automatically.
#
# No whitespace inside the value — "10.99.0.1/32, 2001:db8::1/128" (space after
# the comma) is rejected at startup. Use comma-only separators.
#
# IPv6 address selection: avoid ULA (fd00::/8, fc00::/7). Chrome's Local Network
# Access policy treats ULA as private/local address space, which blocks or prompts
# browser-initiated connections to those addresses.
# Use Global Unicast instead — 2001:db8::/32 (RFC 3849 documentation range) is a
# practical and conflict-free choice for this design's internally routed virtual
# ingress addresses: Chrome treats it as public (no PNA prompt), and no real-world
# public allocation will collide with it. RFC 3849 reserves it for documentation;
# it is not a general public deployment prefix — use space you control for a
# conventionally assigned long-term production address.
# Avoid fd7a:115c:a1e0::/48 (Tailscale's own range) and fe80::/10 (link-local).
#
# IPv4-only (default):
INGRESS_IP=10.99.0.1/32
# Dual-stack:
# INGRESS_IP=10.99.0.1/32,2001:db8::1/128
# IPv6-only (requires clients to have IPv6 tailnet path to this node):
# INGRESS_IP=2001:db8::1/128

# Tailscale auth key. Generate at https://login.tailscale.com/admin/settings/keys
# Recommend an ephemeral reusable key tagged with your connector tag.
TS_AUTHKEY=tskey-auth-xxxx

# =============================================================
# Optional — defaults shown
# =============================================================

# Node hostname in the Tailscale admin console
TS_HOSTNAME=appc-gateway

# Only authenticate on first boot. On restart with existing state in
# ./ts-state/, Tailscale reconnects the existing node without
# re-consuming the auth key or creating a duplicate in the admin console.
# Set to "false" only if using ephemeral keys (which expire on disconnect).
TS_AUTH_ONCE=true

# Upstream DNS forwarders for Unbound (HAProxy resolves SNI hostnames through these).
# Default: Cloudflare + Google over DNS-over-TLS (DoT). Set DNS_UPSTREAM_TLS=no
# and use bare IPs if your upstream doesn't support TLS (e.g. a corporate resolver).
DNS_UPSTREAM_TLS=yes
DNS_UPSTREAM_FORWARDERS=1.1.1.1@853#cloudflare-dns.com,8.8.8.8@853#dns.google

# =============================================================
# Config render skip knobs — operator overrides
# =============================================================
# Set any of these to skip auto-rendering that config file.
# The service will use whatever file is already present in ./config/.
# Useful when you need a hand-crafted config for one component
# without touching the rest.
#
# SKIP_HAPROXY_RENDER=1
# SKIP_DNSMASQ_RENDER=1
# SKIP_UNBOUND_RENDER=1

# =============================================================
# Policy sync — SNI allowlist enforcement
# =============================================================
# The policy-sync sidecar reads domain assignments from Tailscale's
# LocalAPI and generates HAProxy ACLs. These knobs tune its behavior.

# How often (seconds) policy-sync polls Tailscale for domain changes.
# POLICY_SYNC_INTERVAL=30

# Narrow enforcement to specific connector tag(s). Comma-separated.
# Without this, the stack unions all Self.Tags to determine which
# CapMap entries apply. Use when the node has multiple tags but you
# want only a subset to drive this gateway's policy.
# CONNECTOR_TAG=tag:connector

# Disable SNI allowlist enforcement (open mode). deny-cidrs post-
# resolution check stays active regardless. Useful for initial rollout
# or diagnostic use when the SNI ACL is not yet populated.
# SKIP_SNI_ENFORCEMENT=1

# Additional CIDRs to deny as resolved destinations (DNS rebinding
# protection). Comma-separated. Additive only — cannot remove the static base.
# Static base always includes: 127/8, 169.254/16, 224/4, 240/4,
# 100.64.0.0/10, fd7a:115c:a1e0::/48, ::1/128, fe80::/10, ff00::/8.
# 100.64.0.0/10 (IANA CGNAT / Tailscale peer range) and
# fd7a:115c:a1e0::/48 (Tailscale IPv6 node range) are denied by default.
# To allow forwarding to tailnet peers, remove those ranges from the static
# base in config-render/render.sh and policy-sync/sync.sh directly.
# Policy-sync dynamically adds Self.TailscaleIPs + Quad100 on each sync.
# EXTRA_DENY_CIDRS=

# =============================================================
# Egress address-family policy
# =============================================================
# Controls which IP families HAProxy accepts for resolved destinations
# and which family it prefers when both are available.
#
# EGRESS_ACCEPT_FAMILY — strict enforcement via dns-accept-family:
#   ipv4  HAProxy discards AAAA records; egress is IPv4-only (default)
#   ipv6  HAProxy discards A records; egress is IPv6-only
#   dual  Both families accepted; dns-accept-family directive omitted
#
# EGRESS_PREFER_FAMILY — preference hint to do-resolve (no strict effect):
#   ipv4  Prefer A records when both are available (default)
#   ipv6  Prefer AAAA records when both are available
#   none  No preference; only valid when EGRESS_ACCEPT_FAMILY=dual
#
# Valid combinations only (config-render exits 1 on mismatch):
#   accept=ipv4  prefer=ipv4  (strict IPv4)
#   accept=ipv6  prefer=ipv6  (strict IPv6)
#   accept=dual  prefer=ipv4  (dual-stack, IPv4 preferred)
#   accept=dual  prefer=ipv6  (dual-stack, IPv6 preferred)
#   accept=dual  prefer=none  (dual-stack, no preference)
#
# Note: for dual-stack egress, ensure Unbound's forward-addr values
# include IPv6-capable resolvers and the host has IPv6 connectivity.
# EGRESS_ACCEPT_FAMILY=ipv4
# EGRESS_PREFER_FAMILY=ipv4

# =============================================================
# Image pins
# =============================================================
# Override to roll forward deliberately. :latest is not recommended in production.
# Pinned defaults are set in docker-compose.yml; override here to change them.
# TS_IMAGE=tailscale/tailscale:v1.94.2
# HAPROXY_IMAGE=haproxy:3.2.14-alpine
# AUTOHEAL_IMAGE=willfarrell/autoheal:1.2.0    # tools profile only

# =============================================================
# Tailscale admin console setup (not set here — see README)
# =============================================================
# Before running, configure your Tailscale ACL policy with:
#   - tagOwners: define who owns tag:connector
#   - autoApprovers: auto-approve subnet routes from tag:connector
#   - nodeAttrs: map tag:connector to the domains you want to route
# See README.md for the exact policy snippet.
