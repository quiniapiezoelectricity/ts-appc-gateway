# Runtime configs — generated by config-render at startup (or hand-placed
# when a SKIP_*_RENDER knob is set). Do not commit generated files.
config/*
!config/.gitkeep

# Tailscale node state (private keys — never commit)
# Delete this directory to force re-authentication on next start.
ts-state/

# Local environment (contains secrets)
.env

# Tailscale debug envknobs (may contain sensitive DERP addresses or experiment flags)
tailscale-debug.env
