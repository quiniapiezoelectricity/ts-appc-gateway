# dnsmasq-steer — split-horizon steering resolver
# Generated by config-render. Do not edit directly.
#
# Role: return the ingress address(es) for all DNS queries EXCEPT Tailscale
# infrastructure domains, which are forwarded to Unbound for real
# answers. The tailscale container uses this as its system resolver
# so App Connector peerapi resolves configured domains to INGRESS_IP.
#
# Domain routing is managed entirely in the Tailscale admin console
# (nodeAttrs). This resolver has no per-domain list — it relies on
# the fact that App Connector peerapi only queries the connector for
# domains configured in the ACL.

no-resolv
no-hosts
port=53
# No listen-address directive: dnsmasq defaults to all interfaces including
# loopback. Specifying listen-address=0.0.0.0 creates a socket on the wildcard
# but dnsmasq only responds to queries arriving on the listed address — queries
# to 127.0.0.1 would be silently discarded. Omitting it is the correct fix.

# Log all queries to stderr (visible via: docker compose logs dns-steer)
log-queries
log-facility=-

# ----------------------------------------------------------------
# Tailscale infrastructure → real upstream DNS (Unbound → 8.8.8.8)
# Covers all subdomains via dnsmasq wildcard matching:
#   controlplane.tailscale.com, login.tailscale.com, DERP servers, etc.
# ----------------------------------------------------------------
server=/tailscale.com/127.0.0.1#5353
server=/tailscale.io/127.0.0.1#5353
server=/ts.net/127.0.0.1#5353

# ----------------------------------------------------------------
# Everything else → ingress address(es)
# local=/#/ prevents dnsmasq 2.86+ from forwarding non-A/AAAA query
# types (MX, etc.) upstream for the catch-all. More-specific
# server=/tailscale.*/ rules above still take precedence.
# address=/#/ returns an A record for IPv4 addresses and an AAAA
# record for IPv6 addresses. One line per ingress IP from INGRESS_IP.
# ----------------------------------------------------------------
local=/#/
${DNSMASQ_ADDRESS_LINES}
