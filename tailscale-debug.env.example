# Experimental Tailscale internal envknobs for appc-ts.
# Copy to tailscale-debug.env, uncomment desired knobs, then restart the stack:
#   docker compose down && docker compose up -d
#
# Changes to appc-ts require a full-stack restart — sidecars share its network namespace.
#
# These are Tailscale internal debug knobs — not a stable public API.
# Names, values, and behavior may change or disappear across Tailscale releases.
# Do not use in normal production deployments.

# Disable direct UDP paths; traffic will use DERP or peer relay instead:
# TS_DEBUG_NEVER_DIRECT_UDP=true

# Force all peer traffic over DERP specifically (stronger than NEVER_DIRECT_UDP):
# TS_DEBUG_ALWAYS_USE_DERP=true

# Enable verbose DERP relay logging:
# TS_DEBUG_DERP=true

# Enable verbose disco / path-discovery logging:
# TS_DEBUG_DISCO=true

# Enable peer map logging in magicsock:
# TS_DEBUG_MAGICSOCK_PEERMAP=true

# Force a specific DERP server address (IP:port):
# TS_DEBUG_USE_DERP_ADDR=203.0.113.10:443
