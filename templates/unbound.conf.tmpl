# unbound.conf — real upstream resolver
# Generated by config-render. Do not edit directly.
#
# Role: resolve SNI hostnames to actual destination IPs for HAProxy.
# Must NOT be the same resolver used for DNS steering — otherwise
# HAProxy would resolve configured domains to INGRESS_IP and loop.
# Runs in Tailscale's network namespace, bound to loopback only.

server:
    verbosity: 3
    interface: 127.0.0.1@5353
    do-daemonize: no
    do-ip4: yes
    use-syslog: no
    log-time-ascii: yes
    # Container is already isolated by Docker's security model; Unbound
    # need not drop to the 'unbound' system user. Without this, Unbound
    # calls setgid/initgroups which fail under cap_drop: [ALL].
    username: ""

    # Log queries and replies — visible via: docker compose logs appc-dns-upstream
    # Useful for auditing which domains HAProxy is resolving upstream.
    log-queries: yes
    log-replies: yes

    # Loopback only — all clients (HAProxy, dnsmasq) are in the same netns
    access-control: 127.0.0.0/8 allow
    access-control: 0.0.0.0/0   refuse

    # ---- RAM minimisation ----
    # This instance serves only HAProxy (single client, SNI lookups).
    # HAProxy already caches resolved IPs via its resolvers hold settings,
    # so Unbound's cache is a redundant second layer — keep it minimal.
    # Unbound's defaults target a high-throughput recursive resolver;
    # cutting these down keeps RSS well under 10 MB.
    num-threads: 1              # event-driven per thread; cores don't help here
    outgoing-range: 64          # concurrent outgoing sockets; covers burst from HAProxy
    num-queries-per-thread: 100 # in-flight query slots
    msg-cache-size: 1m          # HAProxy caches results; Unbound cache is redundant
    rrset-cache-size: 1m
    key-cache-size: 1m
    neg-cache-size: 512k
    infra-cache-numhosts: 200   # default 10000 — we talk to one upstream forwarder
    prefetch: no
    prefetch-key: no
    minimal-responses: yes

    # Required for DoT certificate verification (forward-tls-upstream: yes)
    tls-cert-bundle: /etc/ssl/certs/ca-certificates.crt

forward-zone:
    name: "."
    forward-tls-upstream: ${DNS_UPSTREAM_TLS}
${DNS_UPSTREAM_FORWARD_ADDRS}
